<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Scoreboards</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
<style>
  :root{
    --bg:#f5f5f7;--card:#fff;--ink:#1d1d1f;--mut:#6e6e73;--faint:#86868b;
    --hair:#e5e5ea;--accent:#d50a0a;--live:#34c759;
    --pill:#f2f2f7;--shadow:0 1px 3px rgba(0,0,0,.04),0 10px 30px rgba(0,0,0,.05);
  }
  *{box-sizing:border-box;margin:0;padding:0}
  body{font-family:'Inter',-apple-system,BlinkMacSystemFont,system-ui,sans-serif;background:var(--bg);color:var(--ink);-webkit-font-smoothing:antialiased;letter-spacing:-.01em}
  .wrap{max-width:760px;margin:0 auto;padding:0 16px}
  .top{position:sticky;top:0;z-index:30;background:rgba(245,245,247,.8);backdrop-filter:saturate(1.8) blur(20px);border-bottom:1px solid var(--hair)}
  .top .wrap{display:flex;align-items:center;gap:12px;height:52px}
  .brand{display:flex;align-items:center;gap:9px;font-weight:800;font-size:15px;letter-spacing:-.02em}
  .brand .bar{width:4px;height:18px;background:var(--accent);border-radius:2px}
  .hero{padding:34px 0 10px}
  .crumb{font-size:12px;font-weight:700;letter-spacing:.04em;text-transform:uppercase;color:var(--accent);margin-bottom:8px}
  .hero h1{font-size:clamp(28px,6vw,42px);font-weight:900;letter-spacing:-.03em;line-height:1}
  .hero p{margin-top:12px;color:var(--mut);font-size:14px;font-weight:500}
  .list{display:flex;flex-direction:column;gap:12px;margin:26px 0 40px}
  a.card{display:flex;align-items:center;gap:16px;background:var(--card);border-radius:16px;padding:16px 18px;box-shadow:var(--shadow);text-decoration:none;color:inherit;transition:transform .12s,box-shadow .12s}
  a.card:hover{transform:translateY(-1px);box-shadow:0 1px 3px rgba(0,0,0,.06),0 14px 36px rgba(0,0,0,.08)}
  .crest{flex:none;width:52px;height:52px;border-radius:14px;background:linear-gradient(150deg,#1d1d1f,#000);display:flex;align-items:center;justify-content:center;box-shadow:0 6px 18px rgba(0,0,0,.18)}
  .crest svg{width:30px;height:30px}
  .c-body{min-width:0;flex:1}
  .c-cat{font-size:11px;font-weight:700;letter-spacing:.04em;text-transform:uppercase;color:var(--faint)}
  .c-title{font-size:18px;font-weight:800;letter-spacing:-.02em;margin:2px 0 0}
  .c-loc{font-size:13px;color:var(--mut);font-weight:500;margin-top:2px}
  .badge{flex:none;font-size:10px;font-weight:800;letter-spacing:.05em;text-transform:uppercase;padding:5px 10px;border-radius:999px}
  .badge.archived{background:var(--pill);color:var(--faint)}
  .badge.live{background:rgba(52,199,89,.12);color:#1c8c3a;display:inline-flex;align-items:center;gap:6px}
  .badge.live .dot{width:7px;height:7px;border-radius:50%;background:var(--live)}
  .chev{flex:none;color:var(--faint);font-size:20px}
  footer{color:var(--faint);font-size:12px;padding:8px 0 50px}
</style>
</head>
<body>
<div class="top"><div class="wrap">
  <div class="brand"><span class="bar"></span>Scoreboards</div>
</div></div>
<div class="wrap">
  <div class="hero">
    <div class="crumb">Tournament Scoreboards</div>
    <h1>Scoreboards</h1>
    <p>Live standings, fixtures, and brackets — one page per tournament.</p>
  </div>
  <div class="list">
  <% entries.each do |t| %>
    <a class="card" href="<%= t.slug %>/">
      <span class="crest" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <circle cx="12" cy="12" r="10" stroke="#fff" stroke-width="1.4"/>
          <path d="M12 8.8 15.04 11.01 13.88 14.59 10.12 14.59 8.96 11.01Z" fill="#fff"/>
          <path d="M12 8.8 12 2.8M15.04 11.01 20.75 9.16M13.88 14.59 17.41 19.44M10.12 14.59 6.59 19.44M8.96 11.01 3.25 9.16" stroke="#fff" stroke-width="1.3" stroke-linecap="round"/>
        </svg>
      </span>
      <span class="c-body">
        <span class="c-cat"><%= t.category %></span>
        <div class="c-title"><%= t.title %></div>
        <% if t.location && !t.location.empty? %><div class="c-loc"><%= t.location %></div><% end %>
      </span>
      <% if t.archived? %>
        <span class="badge archived">Final</span>
      <% elsif t.live? %>
        <span class="badge live"><span class="dot"></span>Live</span>
      <% end %>
      <span class="chev">›</span>
    </a>
  <% end %>
  </div>
  <footer>Generated <%= generated_at %>.</footer>
</div>
</body>
</html>

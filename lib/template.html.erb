<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><%= title %></title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
<style>
  :root{
    --bg:#f5f5f7;--card:#fff;--ink:#1d1d1f;--mut:#6e6e73;--faint:#86868b;
    --hair:#e5e5ea;--hair2:#f0f0f2;--accent:#d50a0a;--live:#34c759;
    --gold:#caa64b;--pill:#f2f2f7;--shadow:0 1px 3px rgba(0,0,0,.04),0 10px 30px rgba(0,0,0,.05);--radius:18px;
  }
  *{box-sizing:border-box;margin:0;padding:0}
  body{font-family:'Inter',-apple-system,BlinkMacSystemFont,system-ui,sans-serif;background:var(--bg);color:var(--ink);-webkit-font-smoothing:antialiased;letter-spacing:-.01em}
  .wrap{max-width:980px;margin:0 auto;padding:0 16px}
  .tnum{font-variant-numeric:tabular-nums}
  .top{position:sticky;top:0;z-index:30;background:rgba(245,245,247,.8);backdrop-filter:saturate(1.8) blur(20px);border-bottom:1px solid var(--hair)}
  .top .wrap{display:flex;align-items:center;gap:12px;height:52px}
  .brand{display:flex;align-items:center;gap:9px;font-weight:800;font-size:15px;letter-spacing:-.02em}
  .brand .bar{width:4px;height:18px;background:var(--accent);border-radius:2px}
  .crumbs{display:flex;align-items:center;gap:8px;min-width:0}
  .crumbs a{color:var(--mut);font-weight:600;text-decoration:none;transition:color .15s}
  .crumbs a:hover{color:var(--ink)}
  .crumbs .sep{color:var(--faint);font-weight:500}
  .crumbs .here{color:var(--ink);font-weight:800;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
  .hero{padding:30px 0 18px;display:flex;align-items:flex-start;gap:18px}
  .crest{flex:none;width:60px;height:60px;border-radius:16px;background:linear-gradient(150deg,#1d1d1f,#000);display:flex;align-items:center;justify-content:center;box-shadow:0 6px 18px rgba(0,0,0,.18);position:relative}
  .crest svg{width:34px;height:34px}.crest:after{content:"";position:absolute;inset:0;border-radius:16px;border:1px solid rgba(255,255,255,.08)}
  .logo{flex:none;width:76px;height:76px;object-fit:contain;filter:drop-shadow(0 4px 10px rgba(0,0,0,.12))}
  .herotext{min-width:0}
  .crumb{font-size:12px;font-weight:700;letter-spacing:.04em;text-transform:uppercase;color:var(--accent);margin-bottom:8px}
  .hero h1{font-size:clamp(30px,6vw,46px);font-weight:900;letter-spacing:-.03em;line-height:1}
  .hero .meta{margin-top:12px;display:flex;align-items:center;gap:8px;flex-wrap:wrap;font-size:13px;color:var(--mut);font-weight:500}
  .hero .meta .d{width:3px;height:3px;border-radius:50%;background:var(--faint)}
  .asof{display:inline-flex;align-items:center;gap:6px;margin-top:14px;font-size:11px;font-weight:700;letter-spacing:.03em;text-transform:uppercase;color:var(--faint);background:var(--pill);padding:5px 11px;border-radius:999px}
  .asof .pulse{width:7px;height:7px;border-radius:50%;background:var(--live);animation:pulse 2s infinite}
  @keyframes pulse{0%{box-shadow:0 0 0 0 rgba(52,199,89,.45)}70%{box-shadow:0 0 0 8px rgba(52,199,89,0)}100%{box-shadow:0 0 0 0 rgba(52,199,89,0)}}
  .tabs{display:flex;gap:4px;background:var(--pill);padding:4px;border-radius:12px;width:fit-content;margin:6px 0 22px}
  .tabs button{border:0;background:transparent;font-family:inherit;font-size:13px;font-weight:600;color:var(--mut);padding:7px 18px;border-radius:9px;cursor:pointer;letter-spacing:-.01em;transition:.15s}
  .tabs button.on{background:var(--card);color:var(--ink);box-shadow:0 1px 2px rgba(0,0,0,.08)}
  .sechead{font-size:13px;font-weight:700;letter-spacing:.06em;text-transform:uppercase;color:var(--faint);margin:30px 0 12px}
  .stand{background:var(--card);border-radius:var(--radius);box-shadow:var(--shadow);overflow:hidden}
  .stand table{width:100%;border-collapse:collapse}
  .stand th{font-size:11px;font-weight:700;letter-spacing:.04em;text-transform:uppercase;color:var(--faint);text-align:right;padding:13px 10px;border-bottom:1px solid var(--hair)}
  .stand th.tm{text-align:left;padding-left:18px}.stand th.rk{text-align:center;width:42px;padding-left:14px}
  .stand td{padding:14px 10px;border-bottom:1px solid var(--hair2);font-size:15px;text-align:right;font-weight:600}
  .stand tr:last-child td{border-bottom:0}
  .stand td.rk{text-align:center;color:var(--faint);font-size:13px;font-weight:700;width:42px}
  .stand td.tm{text-align:left;padding-left:18px;font-weight:600;display:flex;align-items:center;gap:10px}
  .stand th.rec{width:34px;padding:13px 6px;color:var(--faint)}
  .stand td.rec{width:34px;padding:14px 6px;font-size:14px;font-weight:600;color:var(--mut)}
  .stand td.pts{font-weight:800;font-size:16px;padding-right:18px}
  .places{display:grid;grid-template-columns:repeat(auto-fit,minmax(210px,1fr));gap:10px}
  .place{display:flex;align-items:center;gap:11px;background:var(--card);border-radius:14px;box-shadow:var(--shadow);padding:13px 15px;border:1px solid var(--hair2)}
  .place .pn{font-size:20px;font-weight:800;min-width:30px;text-align:center;color:var(--faint);font-variant-numeric:tabular-nums}
  .place.p1{border-color:var(--gold);box-shadow:0 0 0 2px rgba(202,166,75,.18),var(--shadow)}
  .place .pteam{display:flex;align-items:center;gap:10px;font-weight:700;font-size:15px;min-width:0}
  .place .pteam .nm,.place .pteam{white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
  .seed{width:26px;height:26px;border-radius:7px;background:var(--pill);display:inline-flex;align-items:center;justify-content:center;font-size:11px;font-weight:800;color:var(--mut);flex:none}
  tr.q1 .seed{background:var(--gold);color:#fff}tr.q2 .seed{background:#e8e8ed;color:var(--ink)}
  tr.q .rk{color:var(--accent)}tr.q1 td{background:rgba(202,166,75,.06)}
  .games{display:grid;gap:10px}
  .daylabel{font-size:12px;font-weight:700;letter-spacing:.05em;text-transform:uppercase;color:var(--faint);margin:22px 4px 4px}
  .gc{background:var(--card);border-radius:14px;box-shadow:var(--shadow);padding:14px 16px;display:grid;grid-template-columns:1fr auto;gap:6px 14px;align-items:center}
  .gc .status{grid-column:1/-1;display:flex;align-items:center;gap:8px;font-size:11px;font-weight:700;letter-spacing:.03em;text-transform:uppercase;color:var(--faint);margin-bottom:2px}
  .gc .status .fin{color:var(--accent)}.gc .status .when{color:var(--ink);font-weight:700}
  .gc .status .field{margin-left:auto;color:var(--faint);font-weight:600;text-transform:none;letter-spacing:0}
  .tline{display:flex;align-items:center;gap:11px;grid-column:1;min-width:0}
  .tline .nm{font-size:15.5px;font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
  .tline .sd{width:22px;height:22px;border-radius:6px;background:var(--pill);display:inline-flex;align-items:center;justify-content:center;font-size:10px;font-weight:800;color:var(--mut);flex:none}
  .sc{grid-column:2;font-size:19px;font-weight:800;text-align:right;min-width:26px;color:var(--mut);font-variant-numeric:tabular-nums}
  .gc.played .win .nm{font-weight:800}.gc.played .win .sc{color:var(--ink)}
  .gc .lose .sc{color:var(--faint)}.gc .lose .nm{color:var(--mut)}
  .tagrow{grid-column:1/-1;margin-top:2px}
  .tag{font-size:10px;font-weight:800;letter-spacing:.05em;text-transform:uppercase;padding:3px 9px;border-radius:6px}
  .t-final{background:var(--gold);color:#fff}.t-cons{background:var(--pill);color:var(--mut)}
  .bracket{background:var(--card);border-radius:var(--radius);box-shadow:var(--shadow);padding:22px 20px;overflow-x:auto}
  .blegend{font-size:12px;color:var(--mut);font-weight:500;margin-bottom:18px}
  .brow{display:flex;align-items:center;margin:0 0 18px;min-width:480px}.brow:last-child{margin-bottom:0}
  .blabel{flex:none;width:104px;font-size:11px;font-weight:800;letter-spacing:.04em;text-transform:uppercase;color:var(--faint);padding-right:14px;text-align:right}
  .brow.final .blabel{color:var(--gold)}
  .matchup{flex:none;width:230px;border:1px solid var(--hair);border-radius:12px;overflow:hidden}
  .brow.final .matchup{border-color:var(--gold);box-shadow:0 0 0 3px rgba(202,166,75,.15)}
  .slot{display:flex;align-items:center;gap:10px;padding:11px 13px;font-size:14px;font-weight:600}
  .slot+.slot{border-top:1px solid var(--hair2)}
  .slot .sd{width:22px;height:22px;border-radius:6px;background:var(--pill);display:inline-flex;align-items:center;justify-content:center;font-size:10px;font-weight:800;color:var(--mut);flex:none}
  .slot .seedlabel{display:flex;flex-direction:column;gap:1px;min-width:0}
  .slot .seedlabel .lab{font-weight:700}
  .slot .seedlabel .proj{font-size:11px;font-weight:500;color:var(--faint);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
  .slot .bsc{margin-left:auto;font-size:16px;font-weight:800;font-variant-numeric:tabular-nums;color:var(--mut)}
  .slot.win .bsc{color:var(--ink)}.slot.win .lab{font-weight:800}
  .slot.lose .lab{color:var(--mut)}.slot.lose .bsc{color:var(--faint)}
  .slot .bcheck{color:var(--live);font-weight:800;margin-left:8px}
  .slot.lose .bcheck{display:none}
  .bout .winner{color:var(--ink);font-weight:800}.brow.final .bout .winner{color:var(--gold)}
  .brow.final .slot:first-child .sd{background:var(--gold);color:#fff}.brow.final .slot:nth-child(2) .sd{background:#e8e8ed;color:var(--ink)}
  .bconn{flex:none;width:34px;align-self:stretch;position:relative}
  .bconn:before{content:"";position:absolute;left:0;top:50%;width:100%;border-top:2px solid var(--hair)}
  .bout{flex:none;display:flex;align-items:center;gap:9px;font-size:12px;font-weight:700;color:var(--mut)}
  .bout .trophy{font-size:15px}.brow.final .bout{color:var(--gold)}
  footer{color:var(--faint);font-size:12px;padding:36px 0 50px;font-weight:500}
  .hide{display:none}
</style>
</head>
<body>
<div class="top"><div class="wrap">
  <nav class="brand crumbs" aria-label="Breadcrumb"><span class="bar"></span><a href="../">Scoreboards</a><span class="sep">/</span><span class="here" aria-current="page"><%= title %></span></nav>
</div></div>
<div class="wrap">
  <div class="hero">
    <% if logo %>
    <img class="logo" src="<%= logo %>" alt="<%= title %> logo">
    <% else %>
    <div class="crest" aria-hidden="true">
      <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
        <circle cx="12" cy="12" r="10" stroke="#fff" stroke-width="1.4"/>
        <path d="M12 8.8 15.04 11.01 13.88 14.59 10.12 14.59 8.96 11.01Z" fill="#fff"/>
        <path d="M12 8.8 12 2.8M15.04 11.01 20.75 9.16M13.88 14.59 17.41 19.44M10.12 14.59 6.59 19.44M8.96 11.01 3.25 9.16" stroke="#fff" stroke-width="1.3" stroke-linecap="round"/>
      </svg>
    </div>
    <% end %>
    <div class="herotext">
      <div class="crumb"><%= category %></div>
      <h1><%= division %></h1>
      <div class="meta">
        <span><%= data[:teams].size %> teams</span><span class="d"></span>
        <span><%= data[:games].size %> matches</span><span class="d"></span>
        <span>Most points wins</span>
      </div>
      <div class="asof"><span class="pulse"></span>Updated <%= generated_at %></div>
    </div>
  </div>
  <div class="tabs" id="tabs">
    <button data-v="all" class="on">Overview</button>
    <% days.each do |d| %><button data-v="day-<%= day_key(d) %>"><%= short_day(d) %></button><% end %>
    <button data-v="bracket">Bracket</button>
  </div>
  <div id="standwrap">
    <% if placement_complete? %>
    <div class="sechead">Final Placement</div>
    <div class="places">
      <% placed.each do |p| %>
      <div class="place p<%= p[:place] %>">
        <span class="pn"><%= medal(p[:place]) %></span>
        <span class="pteam"><span class="seed"><%= initials(p[:name]) %></span><%= short_name(p[:name]) %></span>
      </div>
      <% end %>
    </div>
    <% end %>
    <div class="sechead"><%= placement_complete? ? 'Group Stage' : 'Standings' %></div>
    <div class="stand"><table>
      <thead><tr><th class="rk">#</th><th class="tm">Team</th><th class="rec">W</th><th class="rec">L</th><th class="rec">D</th><th class="pts" style="padding-right:18px">Pts</th></tr></thead>
      <tbody>
      <% ranked.each_with_index do |t,i| %>
        <tr class="<%= i==0 ? 'q q1' : i==1 ? 'q q2' : '' %>">
          <td class="rk"><%= i+1 %></td>
          <td class="tm"><span class="seed"><%= initials(t[:name]) %></span><%= short_name(t[:name]) %></td>
          <td class="rec tnum"><%= t[:w] %></td>
          <td class="rec tnum"><%= t[:l] %></td>
          <td class="rec tnum"><%= t[:d] %></td>
          <td class="pts tnum"><%= t[:points].nil? ? '—' : t[:points] %></td>
        </tr>
      <% end %>
      </tbody>
    </table></div>
  </div>
  <div class="sechead" id="fixhead">Matches</div>
  <div class="games" id="games"></div>
  <div id="bracketwrap" class="hide">
    <div class="sechead">Placement Round</div>
    <div class="bracket" id="bracket"></div>
  </div>
  <footer>Generated <%= generated_at %> from the tournament CSV. Group stage ranks by points to seed the placement bracket; bracket results set final placement. <%= title %>.</footer>
</div>
<script>
const GAMES = <%= games_json %>;
const RANKED = <%= ranked_json %>;
const DAYS = <%= days_json %>;
const PLACEMENT = <%= placement_json %>;
function shortName(n){return n.replace(/^\d+B?\s+/,'').replace(/^WSM\s+/,'').replace(/\bin Points\b/i,'Seed')}
function initials(n){const s=shortName(n).replace(/^TS\s+/,'');return s.slice(0,2).toUpperCase()}
function dayKey(d){return d.toLowerCase().replace(/[^a-z0-9]+/g,'-')}
function renderGames(filter){
  const g=GAMES.filter(x=>filter==='all'||dayKey(x.day)===filter);
  const days=[...new Set(g.map(x=>x.day))];
  let html='';
  days.forEach(day=>{
    html+=`<div class="daylabel">${day}</div>`;
    g.filter(x=>x.day===day).forEach(x=>{
      const played=x.home_score!=null&&x.away_score!=null;
      const hW=played&&x.home_score>x.away_score, aW=played&&x.away_score>x.home_score;
      const status= played?`<span class="fin">Full · Final</span>`:`<span class="when">${x.time}</span>`;
      const tag= x.label==='Final'?`<span class="tag t-final">Championship Final</span>`
        : x.label==='Consolation'?`<span class="tag t-cons">Consolation</span>`:'';
      html+=`<div class="gc ${played?'played':''}">
        <div class="status">${status}<span class="field">Field ${x.field}${played?'':' · '+x.time}</span></div>
        <div class="tline ${hW?'win':aW?'lose':''}"><span class="sd">${initials(x.home)}</span><span class="nm">${shortName(x.home)}</span></div>
        <div class="sc">${x.home_score==null?'–':x.home_score}</div>
        <div class="tline ${aW?'win':hW?'lose':''}"><span class="sd">${initials(x.away)}</span><span class="nm">${shortName(x.away)}</span></div>
        <div class="sc">${x.away_score==null?'–':x.away_score}</div>
        ${tag?`<div class="tagrow">${tag}</div>`:''}
      </div>`;
    });
  });
  document.getElementById('games').innerHTML=html;
}
function renderBracket(){
  const names=RANKED.map(t=>t.name);
  const ord=["1st Seed","2nd Seed","3rd Seed","4th Seed","5th Seed","6th Seed"];
  const proj=n=>names[n-1]||'TBD';
  const rounds=[{label:"Championship",a:1,b:2,final:true,out:"Champion"}];
  if(names.length>=4) rounds.push({label:"3rd Place",a:3,b:4,final:false,out:"3rd place"});
  if(names.length>=6) rounds.push({label:"5th Place",a:5,b:6,final:false,out:"5th place"});
  // Find the played bracket game pairing two given seeds, if any.
  const gameFor=(a,b)=>GAMES.find(g=>g.seed_game&&g.home_score!=null&&g.away_score!=null&&
    [g.home_seed,g.away_seed].sort().join()===[a,b].sort().join());
  // A slot when the game IS played: real team + score, winner emphasized.
  const playedSlot=(seed,team,score,win)=>`<div class="slot ${win?'win':'lose'}"><span class="sd">${seed}</span><span class="seedlabel"><span class="lab">${shortName(team)}</span><span class="proj">${ord[seed-1]}</span></span><span class="bsc">${score}</span>${win?'<span class="bcheck">✓</span>':''}</div>`;
  // A slot when NOT yet played: projection from current seeding.
  const projSlot=n=>`<div class="slot"><span class="sd">${n}</span><span class="seedlabel"><span class="lab">${ord[n-1]}</span><span class="proj">Projected: ${shortName(proj(n))}</span></span></div>`;
  const anyPlayed=rounds.some(rd=>gameFor(rd.a,rd.b));
  const renderRound=rd=>{
    const g=gameFor(rd.a,rd.b);
    let inner, out;
    if(g){
      const hw=g.home_score>g.away_score;
      // map each game side back to its seed so the higher seed shows on top
      const sideFor=s=>g.home_seed===s?{team:g.home,score:g.home_score,win:hw}:{team:g.away,score:g.away_score,win:!hw};
      const top=sideFor(rd.a), bot=sideFor(rd.b);
      inner=playedSlot(rd.a,top.team,top.score,top.win)+playedSlot(rd.b,bot.team,bot.score,bot.win);
      const winner=top.win?top.team:bot.team;
      out=`${rd.final?'<span class="trophy">🏆</span>':''}<span class="winner">${shortName(winner)}</span>`;
    }else{
      inner=projSlot(rd.a)+projSlot(rd.b);
      out=`${rd.final?'<span class="trophy">🏆</span>':''}${rd.out}`;
    }
    return `<div class="brow ${rd.final?'final':''}"><div class="blabel">${rd.label}</div><div class="matchup">${inner}</div><div class="bconn"></div><div class="bout">${out}</div></div>`;
  };
  const legend=anyPlayed
    ?`<div class="blegend">Final results of the placement bracket. Each game decided two places; the <strong>winner</strong> is checked.</div>`
    :`<div class="blegend">Seeding isn't final until group play ends. Slots show each seed, with the <strong>currently projected</strong> team in grey.</div>`;
  document.getElementById('bracket').innerHTML=legend+rounds.map(renderRound).join('');
}
function setView(v){
  const games=v!=='bracket';
  document.getElementById('games').classList.toggle('hide',!games);
  document.getElementById('fixhead').classList.toggle('hide',!games);
  document.getElementById('standwrap').classList.toggle('hide',v!=='all');
  document.getElementById('bracketwrap').classList.toggle('hide',v!=='bracket');
  if(games) renderGames(v==='all'?'all':v.replace(/^day-/,''));
  if(v==='bracket') renderBracket();
}
document.getElementById('tabs').addEventListener('click',e=>{
  if(e.target.tagName!=='BUTTON')return;
  [...e.currentTarget.children].forEach(b=>b.classList.remove('on'));
  e.target.classList.add('on');setView(e.target.dataset.v);
});
setView('all');
</script>
</body>
</html>
